{
  "name": "discord-logging-handler",
  "version": "2.0.2",
  "type": "module",
  "description": "Discord webhook logger for Node.js. Supports log levels, embeds, timestamps, and error stack traces for real-time monitoring.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mowhite29/discord-logging-handler-js.git"
  },
  "keywords": [
    "discord",
    "logger",
    "logging",
    "webhook",
    "nodejs",
    "error-handling",
    "stack-trace",
    "real-time",
    "monitoring",
    "embed"
  ],
  "author": "Moses White",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mowhite29/discord-logging-handler-js/issues"
  },
  "homepage": "https://github.com/mowhite29/discord-logging-handler-js#readme",
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "axios": "1.16.0"
  },
  "devDependencies": {
    "rollup-plugin-dts": "^6.4.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
